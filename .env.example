# ── Pharos Atlantic testnet ───────────────────────────────────────────────
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689
PHAROS_EXPLORER_URL=https://atlantic.pharosscan.xyz

# Agent signer. Read-only Bastion tools (simulate, assess_risk, guard, explain)
# work WITHOUT this. Only execute / set_policy / on-chain logging need it.
# NEVER commit a real key. This is a testnet key only.
PHAROS_PRIVATE_KEY=

# ── Deployed Bastion contracts (fill in after `npm run deploy`) ────────────
BASTION_POLICY_ADDRESS=
BASTION_REGISTRY_ADDRESS=

# ── Optional external risk enrichment (GoPlus) ─────────────────────────────
# Off by default — Bastion is fully functional without it (graceful degradation).
BASTION_GOPLUS_ENABLED=false
